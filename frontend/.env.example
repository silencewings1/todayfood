# ===== 今日宜吃前端环境配置 =====
# 用法：复制为 .env 并按需修改
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会提交
#
# 仅 VITE_ 前缀的变量会暴露到前端代码（import.meta.env.VITE_XXX）
# 修改后重启 vite dev server 生效

# ===== 开发服务器 =====
# 前端 dev server 端口
VITE_DEV_PORT=5173

# ===== 后端地址 =====
# 开发环境：vite 代理目标（指向 backend/config/app.toml 的 [server].host:port）
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ===== API 前缀 =====
# 前端所有请求都会以此前缀开头，由 vite 代理或 nginx 反代到后端
# 开发与生产保持一致即可，无需改动
VITE_API_BASE=/api
