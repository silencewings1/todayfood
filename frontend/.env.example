# ===== 今日宜吃前端环境配置 =====
# 用法：复制为 .env 并按需修改
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会提交
#
# 仅 VITE_ 前缀的变量会暴露到前端代码（import.meta.env.VITE_XXX）
# 修改后重启 vite dev server 生效

# ===== 开发服务器 =====
# 前端 dev server 端口
VITE_DEV_PORT=5173

# ===== 后端地址 =====
# 开发环境：vite 代理目标（指向 backend/config/app.toml 的 [server].host:port）
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ===== API 前缀 =====
# 前端所有请求都会以此前缀开头，由 vite 代理或 nginx 反代到后端
# 不设时：开发环境默认 /api，生产环境默认 /projects/todayfood/api
# （生产环境嵌入 snowflow 主站，由 nginx 反代到 FastAPI）
VITE_API_BASE=/api

# ===== 子路径部署 =====
# 嵌入 snowflow 主站时的子路径前缀（仅生产环境生效）
# 不设时：开发环境默认 /，生产环境默认 /projects/todayfood/
# 如需独立子域名部署，设为 /
# VITE_BASE_PATH=/
