# ===== 服务 =====
HOST=127.0.0.1
PORT=8000
# 前端开发服务器地址（CORS 白名单）
FRONTEND_ORIGIN=http://localhost:5173

# ===== 时区 =====
TZ=Asia/Shanghai

# ===== AI 接入 =====
# 是否启用 AI（0=关闭，走 DummyProvider；1=启用，使用 openai-agents SDK）
USE_AI=0
# OpenAI API Key（启用 AI 时必填）
OPENAI_API_KEY=
# 可选：兼容代理或自部署服务
OPENAI_BASE_URL=
# 模型名
OPENAI_MODEL=gpt-4o-mini

# ===== 缓存 =====
# 每日食历内存缓存（1=开启，0=关闭）
CACHE_ENABLED=1
