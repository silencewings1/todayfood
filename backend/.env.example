# ===== 今日宜吃后端环境配置 =====
# 用法：复制为 .env 并填入实际值
#   cp .env.example .env
#   vim .env
# .env 已被 .gitignore 忽略，不会提交，可放心填入敏感信息
# 修改后重启后端即生效（--reload 模式会自动重启）
#
# 配置优先级（高 → 低）：
#   环境变量 > .env > config/app.toml + config/ai.toml > 代码默认值
# 大部分非敏感配置已在 config/app.toml 中给出默认值，本文件仅放：
#   1. 敏感信息（API Key、admin 密码）
#   2. 部署期需要快速覆盖的项
# 完整配置说明见 backend/config/app.toml 与 backend/config/ai.toml

# ===== 服务（覆盖 config/app.toml [server]）=====
# HOST=127.0.0.1
# PORT=8000
# 前端地址（CORS 白名单，多个用逗号分隔）
# 生产环境填实际前端域名，例如：https://todayfood.example.com
# FRONTEND_ORIGIN=http://localhost:5173

# ===== 时区 / 缓存（覆盖 config/app.toml [app]）=====
# TZ=Asia/Shanghai
# CACHE_ENABLED=1

# ===== 调度（覆盖 config/app.toml [scheduler]）=====
# SCHEDULER_CHECK_INTERVAL=21600

# ===== AI 接入（详见 config/ai.toml）=====
# 是否启用 AI（1=启用，0=关闭）
# 默认在 config/ai.toml 中已设为 true，此处设 0 可强制关闭
# USE_AI=1

# OpenAI API Key（必填，启用 AI 时）
# 仅从环境变量读取，不入 ai.toml
OPENAI_API_KEY=

# 可选：兼容代理或自部署服务地址（留空走 OpenAI 官方）
# 第三方兼容服务示例：
#   DeepSeek:   https://api.deepseek.com/v1
#   Moonshot:   https://api.moonshot.cn/v1
#   通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1
#   智谱 GLM:   https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL=

# 可选：模型名（默认 gpt-4o-mini）
# 各服务推荐模型：
#   OpenAI:    gpt-4o-mini / gpt-4o
#   DeepSeek:  deepseek-chat
#   通义千问:    qwen-turbo / qwen-plus
OPENAI_MODEL=

# 可选：API 协议 chat_completions | responses（默认 chat_completions）
# 第三方兼容服务通常只支持 chat_completions
# AI_PROTOCOL=chat_completions

# ===== 后台管理（覆盖 config/app.toml [admin]）=====
# admin 后台账号密码（访问 /admin）
# 默认 admin/admin123，生产环境必须修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# admin 独立部署时的监听地址与端口
# ADMIN_HOST=0.0.0.0
# ADMIN_PORT=9082
# 被监控的主后端 health 地址（admin 通过它拉取真实 AI 配置）
# MONITORED_HEALTH_URL=http://127.0.0.1:8000/health

# ===== 说明 =====
# - AI 的完整配置见 backend/config/ai.toml（协议/模型/超时/各 agent 开关）
# - 系统配置见 backend/config/app.toml（端口/CORS/时区/调度/admin）
# - 环境变量优先级高于 toml，便于运维不改文件就能切换
