# ===== 服务 =====
HOST=127.0.0.1
PORT=8000
# 前端开发服务器地址（CORS 白名单）
FRONTEND_ORIGIN=http://localhost:5173

# ===== 时区 =====
TZ=Asia/Shanghai

# ===== AI 接入 =====
# 是否启用 AI（1=启用，0=关闭）
# 默认在 config/ai.toml 中已设为 true，此处设 0 可强制关闭
# USE_AI=0

# OpenAI API Key（启用 AI 时必填，仅在环境变量传入，不入配置文件）
OPENAI_API_KEY=

# 可选：兼容代理或自部署服务（也可在 config/ai.toml 中配置）
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 可选：模型名（也可在 config/ai.toml 中配置）
# OPENAI_MODEL=gpt-4o-mini

# 可选：API 协议 chat_completions | responses（也可在 config/ai.toml 中配置）
# AI_PROTOCOL=chat_completions

# ===== 缓存 =====
# 每日食历内存缓存（1=开启，0=关闭）
CACHE_ENABLED=1

# ===== 说明 =====
# AI 的完整配置见 backend/config/ai.toml（协议/模型/超时/各 agent 开关）
# 环境变量优先级高于 ai.toml，便于运维不改文件就能切换
